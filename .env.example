# Hub Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Feature Limits
MAX_USERS=100
MAX_FILE_SIZE=104857600
MESSAGE_RATE_LIMIT=60

# Security
JWT_SECRET=auto
ADMIN_PASSWORD=
SESSION_TIMEOUT=300000

# WebRTC Configuration
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# SSL Configuration (optional)
HTTPS=false
SSL_KEY=
SSL_CERT=

# Logging
LOG_LEVEL=info
LOG_FILE=

# Development
DEBUG=false